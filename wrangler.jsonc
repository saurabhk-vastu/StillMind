{
  "$schema": "node_modules/wrangler/config-schema.json",

  "name": "stillmind",

  "compatibility_date": "2025-09-24",
  "compatibility_flags": ["nodejs_compat"],

  // SSR worker — without this, deploy uploads only static files and every route 404s.
  "main": "src/server.ts",

  "observability": {
    "enabled": true
  }
}
